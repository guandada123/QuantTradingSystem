apiVersion: v1
kind: Secret
metadata:
  name: quant-secrets
  namespace: quant-trading
type: Opaque
stringData:
  # Database
  POSTGRES_USER: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"
  POSTGRES_DB: "quant_trading"
  DATABASE_URL: "postgresql://CHANGE_ME:CHANGE_ME@postgres.quant-trading.svc.cluster.local:5432/quant_trading"

  # Redis
  REDIS_URL: "redis://redis.quant-trading.svc.cluster.local:6379/0"

  # QuestDB
  QUESTDB_URL: "http://questdb.quant-trading.svc.cluster.local:8812"

  # RabbitMQ
  RABBITMQ_DEFAULT_USER: "CHANGE_ME"
  RABBITMQ_DEFAULT_PASS: "CHANGE_ME"
  RABBITMQ_URL: "amqp://CHANGE_ME:CHANGE_ME@rabbitmq.quant-trading.svc.cluster.local:5672"

  # External APIs (override with actual values)
  TUSHARE_TOKEN: ""
  AKSHARE_TOKEN: ""
  DEEPSEEK_API_KEY: ""
  KIMI_API_KEY: ""
  GLM_API_KEY: ""
  MINIMAX_API_KEY: ""

  # MiniQMT (trading gateway)
  MINIQMT_USER: ""
  MINIQMT_PASSWORD: ""

  # Feishu Alert
  FEISHU_WEBHOOK: ""

  # Grafana
  GF_SECURITY_ADMIN_PASSWORD: "CHANGE_ME"
