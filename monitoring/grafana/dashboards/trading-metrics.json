{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": { "limit": 100, "matchAny": false, "tags": [], "type": "dashboard" },
        "type": "dashboard"
      }
    ]
  },
  "description": "QuantTradingSystem 交易指标仪表盘",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "currencyCNY"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 0 },
      "title": "Total P&L",
      "type": "stat",
      "targets": [
        { "expr": "portfolio_pnl_total", "legendFormat": "Total P&L" }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 0 },
      "title": "Daily Return",
      "type": "stat",
      "targets": [
        { "expr": "portfolio_return_daily", "legendFormat": "Daily %" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 0 },
      "title": "Open Positions",
      "type": "stat",
      "targets": [
        { "expr": "positions_count", "legendFormat": "Positions" }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 0 },
      "title": "Today Signals",
      "type": "stat",
      "targets": [
        { "expr": "signals_generated_today", "legendFormat": "Signals" }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyCNY" } },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 3 },
      "title": "P&L Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "portfolio_pnl_total", "legendFormat": "Total P&L" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 3 },
      "title": "Signal Direction",
      "type": "bargauge",
      "targets": [
        { "expr": "signals_buy_count", "legendFormat": "Buy" },
        { "expr": "signals_sell_count", "legendFormat": "Sell" }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyCNY" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "title": "Position Values",
      "type": "timeseries",
      "targets": [
        { "expr": "position_market_value", "legendFormat": "{{ts_code}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "title": "Win Rate Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "trade_win_rate_7d", "legendFormat": "7d Win Rate" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 21 },
      "title": "Risk Events (24h)",
      "type": "timeseries",
      "targets": [
        { "expr": "risk_events_total", "legendFormat": "Events" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 21 },
      "title": "AI Review Status",
      "type": "stat",
      "targets": [
        { "expr": "ai_review_completed_today > 0", "legendFormat": "Completed" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["quant", "trading", "metrics"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "交易指标",
  "uid": "quant-trading-metrics",
  "version": 1
}
