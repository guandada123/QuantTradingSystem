FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    fastapi==0.104.1 uvicorn==0.24.0 httpx==0.25.1

COPY alertmanager_feishu_adapter.py /app/

EXPOSE 9093

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:9093/health')" || exit 1

CMD ["uvicorn", "alertmanager_feishu_adapter:app", "--host", "0.0.0.0", "--port", "9093"]
