# ============================================
# QuantTradingSystem 环境变量配置（示例）
# 复制此文件为 .env 并填入实际值
# ============================================

# 数据源API密钥
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_ENABLED=true

# 数据源切换（tdx / tushare / akshare）
QTS_DATA_SOURCE=tushare
TDX_CONNECTOR_URL=http://tdx-connector:8300
TDX_MCP_CMD=

# AI模型API密钥
DEEPSEEK_API_KEY=sk-your-deepseek-key
GLM_API_KEY=your-glm-api-key
KIMI_API_KEY=your-kimi-api-key
MINIMAX_API_KEY=your-minimax-api-key

# MiniQMT账号（同花顺）
MINIQMT_USER=your_qmt_username
MINIQMT_PASSWORD=your_qmt_password

# 飞书告警Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# 风险控制参数
MAX_POSITION_RATIO=0.30
MAX_TOTAL_POSITIONS=3
STOP_LOSS_RATIO=0.08
TAKE_PROFIT_RATIO=0.30
MAX_DAILY_LOSS=0.05

# AI预算（美元/月）
AI_BUDGET_TOTAL=500

# 数据库（Docker内部使用，无需修改）
DATABASE_URL=postgresql://quant_user:quant_pass@postgres:5432/quant_trading
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://rabbitmq:5672
