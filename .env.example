# ⚠️ NEVER commit real API keys. Use .env.local for local development.
# ============================================
# QuantTradingSystem 环境变量配置（示例）
# 复制此文件为 .env 并填入实际值
# ============================================

# 数据源API密钥
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_ENABLED=true

# 数据源切换（tdx / tushare / akshare）
QTS_DATA_SOURCE=tushare
TDX_CONNECTOR_URL=http://tdx-connector:8300
TDX_MCP_CMD=

# AI模型API密钥
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
GLM_API_KEY=your-glm-api-key-here
KIMI_API_KEY=your-kimi-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here

# MiniQMT账号（同花顺）
MINIQMT_USER=your_qmt_username
MINIQMT_PASSWORD=your_qmt_password

# 飞书告警Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# 风险控制参数
MAX_POSITION_RATIO=0.30
MAX_TOTAL_POSITIONS=3
STOP_LOSS_RATIO=0.08
TAKE_PROFIT_RATIO=0.30
MAX_DAILY_LOSS=0.05

# AI预算（美元/月）
AI_BUDGET_TOTAL=500

# 数据库（Docker内部使用，可在 docker-compose.yml 中覆盖）
DATABASE_URL=postgresql://your_db_user:your_db_password@postgres:5432/quant_trading
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://your_rabbit_user:your_rabbit_password@rabbitmq:5672

# Docker Compose 安全配置（生产环境务必修改默认密码）
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=quant_trading
RABBITMQ_USER=your_rabbitmq_user_here
RABBITMQ_PASSWORD=your_rabbitmq_password_here
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
ES_PASSWORD=your_es_password_here

# 认证配置
JWT_SECRET_KEY=your-jwt-secret-key-here  # 生产环境使用 openssl rand -hex 32 生成强密钥
API_KEYS=your_internal_api_key_here  # 逗号分隔，服务间调用使用

# CORS 配置
CORS_ORIGINS=http://localhost:3000

# 自动执行信号（true=实盘自动下单）
AUTO_EXECUTE_SIGNALS=false
