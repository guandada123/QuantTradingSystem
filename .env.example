# ═══════════════════════════════════════════════════════════
# QuantTradingSystem 环境变量配置
# ═══════════════════════════════════════════════════════════
#
# 【Profile 系统】
#   .env               — 基础配置（提交 git，存放非敏感默认值）
#   .env.local         — 本地覆盖（不提交 git，存放实际密钥）
#   .env.development   — 开发环境（可提交 git，localhost 地址）
#   .env.production    — 生产环境（不提交 git，真实密钥+域名）
#
# 加载优先级：.env.local > .env.(profile) > .env
# ⚠️ NEVER commit real API keys to .env — use .env.local instead!
# ═══════════════════════════════════════════════════════════

# ─── 数据源 ─────────────────────────────────────────────────
TUSHARE_TOKEN=your_tushare_token_here        # tushare token
AKSHARE_ENABLED=true                          # AkShare 数据源开关

# 数据源切换（tdx / tushare / akshare）
QTS_DATA_SOURCE=tushare
TDX_CONNECTOR_URL=http://tdx-connector:8300  # 通达信连接器
TDX_MCP_CMD=

# ─── AI 模型 ────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
GLM_API_KEY=your-glm-api-key-here
KIMI_API_KEY=your-kimi-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here

# ─── 交易终端 ──────────────────────────────────────────────
MINIQMT_USER=your_qmt_username               # 同花顺 MiniQMT 账号
MINIQMT_PASSWORD=your_qmt_password

# ─── 通知 ──────────────────────────────────────────────────
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# ─── 风控参数 ──────────────────────────────────────────────
MAX_POSITION_RATIO=0.30      # 单标的最大仓位比例
MAX_TOTAL_POSITIONS=3        # 最大同时持仓数
STOP_LOSS_RATIO=0.08         # 止损比例
TAKE_PROFIT_RATIO=0.30       # 止盈比例
MAX_DAILY_LOSS=0.05          # 最大日亏损比例

# ─── AI 预算 ──────────────────────────────────────────────
AI_BUDGET_TOTAL=500          # AI API 月预算（美元）

# ─── 基础设施（Docker 内部地址，docker-compose.yml 覆盖） ──
DATABASE_URL=postgresql://your_db_user:your_db_password@postgres:5432/quant_trading
# REDIS_URL: 单实例模式
# REDIS_SENTINEL_HOSTS: Sentinel 高可用模式（非空时优先）
#   格式: "sentinel1:26379,sentinel2:26379"
# REDIS_SENTINEL_SERVICE_NAME: Sentinel 服务名（默认 mymaster）
REDIS_URL=redis://redis:6379/0
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379
# REDIS_SENTINEL_SERVICE_NAME=mymaster
RABBITMQ_URL=amqp://your_rabbit_user:your_rabbit_password@rabbitmq:5672

# ─── Docker Compose 安全配置（生产环境修改默认密码） ───────
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=quant_trading
RABBITMQ_USER=your_rabbitmq_user_here
RABBITMQ_PASSWORD=your_rabbitmq_password_here
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
ES_PASSWORD=your_es_password_here

# ─── 认证 ──────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here    # openssl rand -hex 32
API_KEYS=your_internal_api_key_here        # 逗号分隔，服务间调用

# ─── 网络 ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── 交易模式 ──────────────────────────────────────────────
AUTO_EXECUTE_SIGNALS=false   # true=实盘自动下单

# ─── 开发环境覆盖示例（.env.development） ──────────────────
# 仅举例，实际使用时去掉注释并复制到 .env.development
# DATABASE_URL=postgresql://quant_user:quant_pass@localhost:5432/quant_trading
# REDIS_URL=redis://localhost:6379/0
# CORS_ORIGINS=http://localhost:3000,http://localhost:3030
