{
  "openapi": "3.0.3",
  "info": {
    "title": "交易执行服务 - QuantTradingSystem",
    "description": "A股量化交易系统的交易执行微服务，覆盖订单生命周期管理、持仓监控、风险控制。",
    "version": "1.1.0",
    "contact": {"name": "QuantTradingSystem Team"}
  },
  "servers": [
    {"url": "http://localhost:8001", "description": "本地开发"},
    {"url": "http://execution-service:8001", "description": "Docker 内部"}
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "服务根路径",
        "tags": ["系统"],
        "responses": {
          "200": {
            "description": "服务信息",
            "content": {
              "application/json": {
                "example": {"service": "QuantTradingSystem Execution Service", "version": "1.1.0", "status": "running"}
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "健康检查",
        "tags": ["系统"],
        "responses": {"200": {"description": "健康状态", "content": {"application/json": {"example": {"status": "healthy"}}}}}
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus 指标端点",
        "tags": ["系统"],
        "responses": {"200": {"description": "Prometheus 指标"}}
      }
    },
    "/api/v1/orders/": {
      "post": {
        "summary": "创建订单",
        "description": "包含风控检查，不自动执行",
        "tags": ["订单管理"],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {"ts_code": "600519.SH", "action": "BUY", "quantity": 100, "price": 1800.0, "order_type": "LIMIT"}
            }
          }
        },
        "responses": {"200": {"description": "创建的订单"}, "400": {"description": "风控拒绝"}}
      },
      "get": {
        "summary": "查询订单列表",
        "tags": ["订单管理"],
        "parameters": [
          {"name": "account_id", "in": "query", "schema": {"type": "string"}},
          {"name": "status", "in": "query", "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "订单列表"}}
      }
    },
    "/api/v1/orders/submit": {
      "post": {
        "summary": "提交订单（创建+立即执行）",
        "tags": ["订单管理"],
        "responses": {"200": {"description": "执行结果"}}
      }
    },
    "/api/v1/orders/{order_id}/execute": {
      "post": {
        "summary": "执行挂起的订单",
        "tags": ["订单管理"],
        "parameters": [
          {"name": "order_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "执行结果"}}
      }
    },
    "/api/v1/orders/{order_id}/cancel": {
      "post": {
        "summary": "撤销订单",
        "tags": ["订单管理"],
        "parameters": [
          {"name": "order_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "撤销结果"}}
      }
    },
    "/api/v1/orders/{order_id}": {
      "get": {
        "summary": "查询订单状态",
        "tags": ["订单管理"],
        "parameters": [
          {"name": "order_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "订单详情"}}
      }
    },
    "/api/v1/orders/summary/daily": {
      "get": {
        "summary": "当日交易摘要",
        "tags": ["订单管理"],
        "responses": {"200": {"description": "当日订单摘要"}}
      }
    },
    "/api/v1/orders/stop/check": {
      "post": {
        "summary": "扫描STOP条件单",
        "description": "扫描并执行已触发的条件单",
        "tags": ["订单管理"],
        "responses": {"200": {"description": "检查结果"}}
      }
    },
    "/api/v1/orders/expire": {
      "post": {
        "summary": "取消过期限价单",
        "tags": ["订单管理"],
        "responses": {"200": {"description": "取消结果"}}
      }
    },
    "/api/v1/positions/": {
      "get": {
        "summary": "获取持仓列表",
        "tags": ["持仓管理"],
        "parameters": [
          {"name": "account_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "持仓列表"}}
      }
    },
    "/api/v1/positions/summary": {
      "get": {
        "summary": "获取持仓汇总",
        "tags": ["持仓管理"],
        "parameters": [
          {"name": "account_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "持仓汇总信息"}}
      }
    },
    "/api/v1/positions/close": {
      "post": {
        "summary": "平仓",
        "tags": ["持仓管理"],
        "responses": {"200": {"description": "平仓结果"}}
      }
    },
    "/api/v1/positions/update-prices": {
      "post": {
        "summary": "批量更新持仓价格",
        "tags": ["持仓管理"],
        "responses": {"200": {"description": "更新结果"}}
      }
    },
    "/api/v1/positions/summary/pnl": {
      "get": {
        "summary": "当日已实现盈亏",
        "tags": ["持仓管理"],
        "responses": {"200": {"description": "盈亏数据"}}
      }
    },
    "/api/v1/positions/{ts_code}": {
      "get": {
        "summary": "获取单只股票持仓",
        "tags": ["持仓管理"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "account_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "单只持仓详情"}}
      }
    },
    "/api/v1/risk/check/{ts_code}": {
      "get": {
        "summary": "检查交易风险",
        "tags": ["风险控制"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "action", "in": "query", "schema": {"type": "string", "enum": ["BUY", "SELL"]}},
          {"name": "quantity", "in": "query", "schema": {"type": "integer"}},
          {"name": "price", "in": "query", "schema": {"type": "number"}}
        ],
        "responses": {"200": {"description": "风控检查通过"}, "403": {"description": "风控拒绝"}}
      }
    },
    "/api/v1/risk/monitor": {
      "get": {
        "summary": "监控持仓止损/止盈",
        "description": "含自动执行止损止盈",
        "tags": ["风险控制"],
        "responses": {"200": {"description": "监控结果"}}
      }
    },
    "/api/v1/risk/events": {
      "get": {
        "summary": "风险事件列表",
        "tags": ["风险控制"],
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "风险事件列表"}}
      }
    },
    "/api/v1/risk/settings": {
      "get": {
        "summary": "当前风控参数",
        "tags": ["风险控制"],
        "responses": {
          "200": {
            "description": "风控参数",
            "content": {
              "application/json": {
                "example": {
                  "max_position_ratio": 0.3, "max_total_positions": 3,
                  "stop_loss_ratio": 0.08, "take_profit_ratio": 0.3, "max_daily_loss": 0.05
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/risk/circuit-breaker": {
      "get": {
        "summary": "查询熔断器状态",
        "tags": ["风险控制"],
        "responses": {"200": {"description": "熔断器状态"}}
      }
    },
    "/api/v1/risk/circuit-breaker/reset": {
      "post": {
        "summary": "手动重置熔断器",
        "tags": ["风险控制"],
        "responses": {"200": {"description": "重置结果"}}
      }
    }
  },
  "tags": [
    {"name": "系统", "description": "系统级端点"},
    {"name": "订单管理", "description": "订单创建、执行、撤销、查询"},
    {"name": "持仓管理", "description": "持仓查询、汇总、平仓"},
    {"name": "风险控制", "description": "风控检查、止损止盈监控、熔断器"}
  ]
}
