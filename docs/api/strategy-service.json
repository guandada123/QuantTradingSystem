{
  "openapi": "3.0.3",
  "info": {
    "title": "策略研究服务 - QuantTradingSystem",
    "description": "A股量化交易系统核心微服务，提供股票数据分析、AI选股、策略回测、信号生成等能力。",
    "version": "2.0.0",
    "contact": {
      "name": "QuantTradingSystem Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "本地开发"
    },
    {
      "url": "http://strategy-service:8000",
      "description": "Docker 内部"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "服务根路径",
        "description": "返回服务名称和版本信息",
        "tags": ["系统"],
        "responses": {
          "200": {
            "description": "服务信息",
            "content": {
              "application/json": {
                "example": {"service": "QuantTradingSystem Strategy Service", "version": "2.0.0", "status": "running"}
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "健康检查",
        "tags": ["系统"],
        "responses": {
          "200": {
            "description": "健康状态",
            "content": {"application/json": {"example": {"status": "healthy"}}}
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus 指标端点",
        "tags": ["系统"],
        "responses": {
          "200": {"description": "Prometheus 指标"}
        }
      }
    },
    "/ws": {
      "get": {
        "summary": "WebSocket 实时行情推送",
        "description": "建立 WebSocket 连接，每3秒广播一次指数行情。支持 subscribe 订阅指定股票。",
        "tags": ["系统"],
        "responses": {
          "101": {"description": "WebSocket 协议升级"}
        }
      }
    },
    "/api/v1/stocks/realtime/{ts_code}": {
      "get": {
        "summary": "获取股票实时行情",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}, "example": "600519.SH"}
        ],
        "responses": {
          "200": {
            "description": "实时行情响应",
            "content": {
              "application/json": {
                "example": {
                  "code": 0, "data": {"ts_code": "600519.SH", "name": "贵州茅台", "price": 1810.0, "pct_change": 1.12, "volume": 5000000, "amount": 9.05e9},
                  "message": "success"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stocks/daily/{ts_code}": {
      "get": {
        "summary": "获取股票日K线数据",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "start_date", "in": "query", "schema": {"type": "string"}},
          {"name": "end_date", "in": "query", "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 100}}
        ],
        "responses": {"200": {"description": "日K线数据列表"}}
      }
    },
    "/api/v1/stocks/minute/{ts_code}": {
      "get": {
        "summary": "获取分钟级K线",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "freq", "in": "query", "schema": {"type": "string", "enum": ["1min", "5min", "15min", "30min", "60min"], "default": "5min"}},
          {"name": "count", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "分钟K线数据列表"}}
      }
    },
    "/api/v1/stocks/index/realtime": {
      "get": {
        "summary": "获取核心指数行情",
        "description": "上证指数、深证成指、创业板指、科创50、北证50、沪深300、中证500、中证1000",
        "tags": ["股票数据"],
        "responses": {"200": {"description": "8个核心指数行情"}}
      }
    },
    "/api/v1/stocks/fundamental/{ts_code}": {
      "get": {
        "summary": "获取股票基本面数据",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "PE/PB/市值等基本面指标"}}
      }
    },
    "/api/v1/stocks/money-flow/{ts_code}": {
      "get": {
        "summary": "获取资金流向数据",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "days", "in": "query", "schema": {"type": "integer", "default": 5}}
        ],
        "responses": {"200": {"description": "资金流向数据"}}
      }
    },
    "/api/v1/stocks/northbound-flow": {
      "get": {
        "summary": "获取北向资金流向",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "date", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "北向资金数据"}}
      }
    },
    "/api/v1/stocks/pool": {
      "get": {
        "summary": "获取股票池",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "industry", "in": "query", "schema": {"type": "string"}},
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "股票池列表"}}
      }
    },
    "/api/v1/stocks/search": {
      "get": {
        "summary": "搜索股票",
        "description": "按代码或名称模糊匹配",
        "tags": ["股票数据"],
        "parameters": [
          {"name": "keyword", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 10}}
        ],
        "responses": {"200": {"description": "匹配的股票列表"}}
      }
    },
    "/api/v1/signals/generate/{ts_code}": {
      "post": {
        "summary": "生成交易信号",
        "description": "调用多智能体AI分析指定股票，生成买卖信号并保存到数据库",
        "tags": ["交易信号"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "生成的信号"}}
      }
    },
    "/api/v1/signals/history": {
      "get": {
        "summary": "查询历史交易信号",
        "tags": ["交易信号"],
        "parameters": [
          {"name": "ts_code", "in": "query", "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "历史信号列表"}}
      }
    },
    "/api/v1/signals/latest/{ts_code}": {
      "get": {
        "summary": "获取最新交易信号",
        "tags": ["交易信号"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "最新信号"}}
      }
    },
    "/api/v1/backtest/run": {
      "post": {
        "summary": "运行策略回测（V2引擎）",
        "description": "执行单/多策略回测，使用 EnhancedBacktestEngine V2",
        "tags": ["回测"],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "ts_code": "600519.SH", "strategies": ["ma-cross", "breakout"],
                "start_date": "2024-01-01", "end_date": "2025-01-01", "initial_cash": 100000
              }
            }
          }
        },
        "responses": {"200": {"description": "回测结果"}}
      }
    },
    "/api/v1/backtest/result/{backtest_id}": {
      "get": {
        "summary": "查询回测结果",
        "tags": ["回测"],
        "parameters": [
          {"name": "backtest_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "回测详情"}}
      }
    },
    "/api/v1/backtest/history": {
      "get": {
        "summary": "查询历史回测记录",
        "tags": ["回测"],
        "responses": {"200": {"description": "回测历史列表"}}
      }
    },
    "/api/v1/backtest/optimize": {
      "post": {
        "summary": "参数优化",
        "tags": ["回测"],
        "responses": {"200": {"description": "优化结果"}}
      }
    },
    "/api/v1/backtest/strategies": {
      "get": {
        "summary": "列出可用策略",
        "tags": ["回测"],
        "responses": {
          "200": {
            "description": "策略列表",
            "content": {
              "application/json": {
                "example": {
                  "data": [
                    {"name": "ma-cross", "description": "双均线金叉策略"},
                    {"name": "breakout", "description": "突破高点策略"},
                    {"name": "rsi", "description": "RSI超买超卖策略"},
                    {"name": "macd", "description": "MACD金叉策略"},
                    {"name": "kdj", "description": "KDJ交叉策略"}
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/backtest/reports": {
      "get": {
        "summary": "查询回测报告",
        "tags": ["回测"],
        "parameters": [
          {"name": "report_type", "in": "query", "schema": {"type": "string"}},
          {"name": "report_date", "in": "query", "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 10}}
        ],
        "responses": {"200": {"description": "回测报告列表"}}
      }
    },
    "/api/v1/backtest/report/generate": {
      "post": {
        "summary": "触发生成回测报告",
        "tags": ["回测"],
        "parameters": [
          {"name": "report_type", "in": "query", "schema": {"type": "string", "enum": ["daily", "weekly", "monthly"]}}
        ],
        "responses": {"200": {"description": "生成结果"}}
      }
    },
    "/api/v1/ai/analyze/{ts_code}": {
      "post": {
        "summary": "多智能体AI分析股票",
        "description": "使用DeepSeek等多模型对比分析，生成技术面+基本面+消息面综合研判",
        "tags": ["AI分析"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "AI分析报告"}}
      }
    },
    "/api/v1/ai/cost-summary": {
      "get": {
        "summary": "AI调用成本统计",
        "tags": ["AI分析"],
        "responses": {"200": {"description": "成本统计"}}
      }
    },
    "/api/v1/ai/models": {
      "get": {
        "summary": "可用AI模型列表",
        "tags": ["AI分析"],
        "responses": {
          "200": {
            "description": "模型列表（10个）",
            "content": {"application/json": {"example": {"code": 0, "data": [{"name": "DeepSeek-V3", "provider": "deepseek"}]}}}
          }
        }
      }
    },
    "/api/v1/ai/scan": {
      "post": {
        "summary": "AI全市场选股扫描",
        "tags": ["AI分析"],
        "parameters": [
          {"name": "strategy", "in": "query", "schema": {"type": "string", "default": "all"}},
          {"name": "top_n", "in": "query", "schema": {"type": "integer", "default": 20}}
        ],
        "responses": {"200": {"description": "扫描结果"}}
      }
    },
    "/api/v1/ai/review": {
      "get": {
        "summary": "AI每日复盘分析",
        "tags": ["AI分析"],
        "parameters": [
          {"name": "date", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "复盘分析报告"}}
      }
    },
    "/api/v1/account/summary": {
      "get": {
        "summary": "账户概要",
        "tags": ["账户"],
        "responses": {"200": {"description": "账户概要信息"}}
      }
    },
    "/api/v1/account": {
      "get": {
        "summary": "账户详情",
        "tags": ["账户"],
        "responses": {"200": {"description": "账户详细信息"}}
      }
    },
    "/api/v1/account/positions": {
      "get": {
        "summary": "持仓列表",
        "tags": ["账户"],
        "parameters": [
          {"name": "ts_code", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "持仓列表"}}
      }
    },
    "/api/v1/trades": {
      "get": {
        "summary": "交易记录列表",
        "tags": ["交易记录"],
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}},
          {"name": "offset", "in": "query", "schema": {"type": "integer", "default": 0}},
          {"name": "direction", "in": "query", "schema": {"type": "string", "enum": ["BUY", "SELL"]}}
        ],
        "responses": {"200": {"description": "交易记录列表"}}
      }
    },
    "/api/v1/trades/stats": {
      "get": {
        "summary": "交易统计",
        "tags": ["交易记录"],
        "responses": {"200": {"description": "交易统计数据"}}
      }
    },
    "/api/v1/scheduler/tasks": {
      "get": {
        "summary": "列出所有定时任务",
        "tags": ["定时任务"],
        "responses": {"200": {"description": "定时任务列表"}}
      }
    },
    "/api/v1/scheduler/tasks/{action}": {
      "post": {
        "summary": "管理定时任务",
        "description": "支持 pause/resume/remove 操作",
        "tags": ["定时任务"],
        "parameters": [
          {"name": "action", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "job_id", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "操作结果"}}
      }
    },
    "/api/v1/scheduler/status": {
      "get": {
        "summary": "调度器运行状态",
        "tags": ["定时任务"],
        "responses": {"200": {"description": "调度器状态"}}
      }
    },
    "/api/v1/strategies/": {
      "get": {
        "summary": "策略列表",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "type", "in": "query", "schema": {"type": "string", "enum": ["builtin", "custom"]}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["active", "draft", "archived"]}}
        ],
        "responses": {"200": {"description": "策略列表"}}
      },
      "post": {
        "summary": "创建自定义策略",
        "tags": ["策略市场"],
        "responses": {"200": {"description": "创建结果"}}
      }
    },
    "/api/v1/strategies/{strategy_id}": {
      "get": {
        "summary": "策略详情",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "strategy_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "策略详情"}}
      },
      "put": {
        "summary": "更新策略",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "strategy_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "更新结果"}}
      },
      "delete": {
        "summary": "删除策略",
        "description": "内置策略不可删除",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "strategy_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "删除结果"}}
      }
    },
    "/api/v1/strategies/{strategy_id}/backtest": {
      "post": {
        "summary": "对指定策略运行回测",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "strategy_id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "ts_code", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "回测结果"}}
      }
    },
    "/api/v1/strategies/compare": {
      "post": {
        "summary": "多策略对比回测",
        "tags": ["策略市场"],
        "responses": {"200": {"description": "对比结果"}}
      }
    },
    "/api/v1/strategies/ranking": {
      "get": {
        "summary": "策略排行榜",
        "tags": ["策略市场"],
        "parameters": [
          {"name": "metric", "in": "query", "schema": {"type": "string", "enum": ["sharpe", "total_return", "win_rate"]}}
        ],
        "responses": {"200": {"description": "排行榜"}}
      }
    },
    "/api/v1/execution/signal-execute": {
      "post": {
        "summary": "执行交易信号",
        "description": "提交订单到 execution-service",
        "tags": ["执行联动"],
        "responses": {"200": {"description": "执行结果"}}
      }
    },
    "/api/v1/execution/positions": {
      "get": {
        "summary": "代理查询持仓",
        "description": "转发到 execution-service 持仓查询",
        "tags": ["执行联动"],
        "parameters": [
          {"name": "account_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "持仓列表"}}
      }
    },
    "/api/v1/execution/risk-check/{ts_code}": {
      "get": {
        "summary": "代理风控检查",
        "tags": ["执行联动"],
        "parameters": [
          {"name": "ts_code", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "风控检查结果"}}
      }
    },
    "/api/v1/execution/config": {
      "get": {
        "summary": "获取自动交易配置",
        "tags": ["执行联动"],
        "responses": {"200": {"description": "配置信息"}}
      },
      "post": {
        "summary": "设置自动交易配置",
        "tags": ["执行联动"],
        "responses": {"200": {"description": "配置结果"}}
      }
    },
    "/api/v1/config/data-source": {
      "get": {
        "summary": "获取当前数据源配置",
        "tags": ["数据源配置"],
        "responses": {
          "200": {
            "description": "数据源状态",
            "content": {
              "application/json": {
                "example": {
                  "current_source": "tushare",
                  "available_sources": ["tdx", "tushare", "akshare"]
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "切换数据源",
        "tags": ["数据源配置"],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {"source": "tdx"}
            }
          }
        },
        "responses": {
          "200": {"description": "切换结果"},
          "400": {"description": "无效的数据源名称"}
        }
      }
    }
  },
  "tags": [
    {"name": "系统", "description": "系统级端点和健康检查"},
    {"name": "股票数据", "description": "实时行情、K线、基本面、资金流向等"},
    {"name": "交易信号", "description": "AI生成的买卖信号"},
    {"name": "回测", "description": "策略回测引擎 V1 & V2"},
    {"name": "AI分析", "description": "多智能体AI股票分析和选股"},
    {"name": "账户", "description": "账户与持仓管理"},
    {"name": "交易记录", "description": "交易历史记录"},
    {"name": "定时任务", "description": "调度任务管理"},
    {"name": "策略市场", "description": "策略CRUD和排行榜"},
    {"name": "执行联动", "description": "与execution-service的代理接口"},
    {"name": "数据源配置", "description": "运行时数据源切换（tdx/tushare/akshare）"}
  ]
}
